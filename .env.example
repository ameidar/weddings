# Copy this file to .dev.vars for local development only.
# Do NOT commit real keys, tokens, passwords, or secrets.

# Admin auth
ADMIN_USERNAME=admin
# SHA-256 hex of the admin password, not the plain password.
ADMIN_PASSWORD_HASH=<sha256_hex_of_admin_password>
# Long random string used to sign sessions. Generate with: openssl rand -hex 32
SESSION_SECRET=<random_64_hex_chars>

# WhatsApp / Green API - optional, required for sending WhatsApp messages
GREENAPI_ID_INSTANCE=<green_api_id_instance>
GREENAPI_API_TOKEN_INSTANCE=<green_api_token_instance>

# Cloudflare KV is NOT defined here as a secret.
# Configure it in Cloudflare Pages as a KV binding named EVENTS_KV.
